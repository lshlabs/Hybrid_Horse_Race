{
  "name": "hybrid-horse-race-functions",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22"
  },
  "main": "lib/functions/src/index.js",
  "scripts": {
    "build": "npm run clean && tsc --project tsconfig.json",
    "clean": "rimraf lib",
    "dev": "npm run build -- --watch",
    "test": "tsx --test test/**/*.test.ts",
    "security:audit:json": "npm audit --omit=dev --json",
    "security:audit:prod": "npm audit --omit=dev",
    "security:audit:high": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  }
}
