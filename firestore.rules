rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function roomRef(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function participantAuthRef(roomId, playerId) {
      return /databases/$(database)/documents/rooms/$(roomId)/participantAuth/$(playerId);
    }

    function playerRef(roomId, playerId) {
      return /databases/$(database)/documents/rooms/$(roomId)/players/$(playerId);
    }

    function isAuthenticated() {
      return request.auth != null && request.auth.uid is string && request.auth.uid.size() > 0;
    }

    function isRoomFresh(roomData) {
      return roomData.createdAt is timestamp &&
        request.time < roomData.createdAt + duration.value(7, 'd');
    }

    // roomId 기반 공개 읽기 범위를 줄이기 위해, 룸 신선도 외에
    // "현재 host의 participantAuth가 유효한지"까지 확인한다.
    function hasActiveHostAuth(roomId, roomData) {
      return roomData.hostId is string &&
        roomData.hostId.size() > 0 &&
        exists(participantAuthRef(roomId, roomData.hostId)) &&
        get(participantAuthRef(roomId, roomData.hostId)).data.status in ['active', 'pending_leave'] &&
        get(participantAuthRef(roomId, roomData.hostId)).data.expiresAt is timestamp &&
        request.time < get(participantAuthRef(roomId, roomData.hostId)).data.expiresAt;
    }

    // request.auth.uid가 현재 room의 참가자로 등록된 경우에만 민감 데이터를 읽게 한다.
    function isSelfPlayerInRoom(roomId) {
      return isAuthenticated() &&
        exists(playerRef(roomId, request.auth.uid)) &&
        get(playerRef(roomId, request.auth.uid)).data.authUid == request.auth.uid;
    }

    function canReadLobbyRoom(roomId, roomData) {
      return isAuthenticated() &&
        isRoomFresh(roomData) &&
        (
          isSelfPlayerInRoom(roomId) ||
          hasActiveHostAuth(roomId, roomData)
        );
    }

    function canReadRoomFromParent(roomId) {
      return exists(roomRef(roomId)) &&
        canReadLobbyRoom(roomId, get(roomRef(roomId)).data);
    }

    // 룸 문서
    match /rooms/{roomId} {
      // 읽기:
      // - get만 허용(rooms 전체 list 차단)
      // - 익명 Auth 사용자만 허용
      // - roomId를 알고 있고, 최근 생성된 룸(7일)이며
      //   (참가자 본인이거나, 참가 직전 로비 접근을 위한 host auth 유효 룸)만 허용
      // 쓰기: Cloud Functions만 가능 (보안을 위해)
      allow get: if resource != null && canReadLobbyRoom(roomId, resource.data);
      allow list: if false;
      allow write: if false;

      // 플레이어 서브컬렉션
      match /players/{playerId} {
        // 읽기:
        // - request.auth.uid가 해당 room 참가자로 확인된 경우만 허용
        allow get, list: if isSelfPlayerInRoom(roomId);
        allow write: if false;
      }

      // 세트 서브컬렉션
      match /sets/{setId} {
        // 읽기:
        // - request.auth.uid가 해당 room 참가자로 확인된 경우만 허용
        // - list는 불허(불필요한 전체 세트 스캔 차단)
        allow get: if isSelfPlayerInRoom(roomId);
        allow list: if false;
        allow write: if false;
      }

      // participantAuth는 클라이언트 비공개
      match /participantAuth/{playerId} {
        allow read: if false;
        allow write: if false;
      }

      // 로그 서브컬렉션 (선택사항)
      match /logs/{logId} {
        // 로그는 클라이언트 비공개
        allow read: if false;
        allow write: if false;
      }
    }
  }
}
